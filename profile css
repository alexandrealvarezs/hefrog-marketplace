
.profile-header{background:var(--bg-white);border-radius:12px;box-shadow:var(--shadow-sm);overflow:hidden;margin-bottom:16px}
.profile-banner{height:160px;background:linear-gradient(135deg,var(--primary-blue),var(--accent-orange))}
.profile-info{display:grid;grid-template-columns:auto 1fr auto;gap:16px;align-items:center;padding:16px;margin-top:-60px}
.profile-avatar-large{width:110px;height:110px;border-radius:999px;background:linear-gradient(135deg,var(--primary-blue),var(--accent-orange));display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:1.6rem;border:4px solid #fff}
.profile-section{background:var(--bg-white);border-radius:12px;box-shadow:var(--shadow-sm);padding:16px;margin-bottom:16px}
.profile-tabs{display:flex}
.tab-btn{flex:1;padding:10px;border:none;background:#f4f6fb;font-weight:700}
.tab-btn.active{background:#fff;color:var(--primary-blue);border-bottom:3px solid var(--primary-blue)}
.tab-pane{display:none}.tab-pane.active{display:block}
.info-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
